// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AppRole {
  ADMIN
  PAYROLL_MANAGER
  PAYROLL_STAFF
  EMPLOYEE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTUAL
  PROBATIONARY
  PROJECT_BASED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  RESIGNED
  TERMINATED
  ON_LEAVE
}

enum PayrollStatus {
  DRAFT
  PENDING
  FINALIZED
  CANCELLED
}

enum PayrollDetailType {
  EARNING
  DEDUCTION
  CONTRIBUTION
  TAX
  ADJUSTMENT
}

enum AllowanceFrequency {
  ONE_TIME
  MONTHLY
  PAYROLL_PERIOD
}

enum DeductionFrequency {
  ONE_TIME
  MONTHLY
  PAYROLL_PERIOD
}

enum DeductionType {
  LOAN
  CASH_ADVANCE
  MANUAL
  OTHER
}

enum GovernmentAgency {
  BIR
  SSS
  PHILHEALTH
  PAG_IBIG
  DOLE
  COMPANY
}

enum RuleStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum HolidayType {
  REGULAR
  SPECIAL
  COMPANY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  REST_DAY
  HOLIDAY
  ON_LEAVE
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  GENERATE
  FINALIZE
}

model UserRole {
  userId    String   @id @map("user_id") @db.Uuid
  role      AppRole  @default(EMPLOYEE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_roles")
}

model Employee {
  id             String           @id @default(uuid()) @db.Uuid
  employeeNumber String           @unique
  firstName      String
  lastName       String
  middleName     String?
  email          String?          @unique
  phoneNumber    String?
  employmentType EmploymentType
  status         EmployeeStatus   @default(ACTIVE)
  department     String?
  position       String?
  hireDate       DateTime
  separationDate DateTime?
  monthlySalary  Decimal          @db.Decimal(12, 2)
  taxId          String?
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  allowances     Allowance[]
  attendances    Attendance[]
  deductions     Deduction[]
  leaveCredits   LeaveCredit[]
  payrolls       Payroll[]

  @@index([lastName, firstName])
  @@index([status])
  @@map("employees")
}

model Payroll {
  id                  String          @id @default(uuid()) @db.Uuid
  payrollNumber       String          @unique
  employeeId          String          @db.Uuid
  periodStart         DateTime
  periodEnd           DateTime
  payDate             DateTime
  status              PayrollStatus   @default(DRAFT)
  grossPay            Decimal         @db.Decimal(12, 2)
  netPay              Decimal         @db.Decimal(12, 2)
  totalEarnings       Decimal         @db.Decimal(12, 2)
  totalDeductions     Decimal         @db.Decimal(12, 2)
  totalContributions  Decimal         @db.Decimal(12, 2)
  totalTax            Decimal         @db.Decimal(12, 2)
  remarks             String?
  metadata            Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  employee            Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  details             PayrollDetail[]

  @@index([employeeId, periodStart, periodEnd])
  @@index([status])
  @@map("payrolls")
}

model PayrollDetail {
  id          String            @id @default(uuid()) @db.Uuid
  payrollId   String            @db.Uuid
  type        PayrollDetailType
  code        String
  name        String
  description String?
  quantity    Decimal?          @db.Decimal(12, 2)
  rate        Decimal?          @db.Decimal(12, 4)
  amount      Decimal           @db.Decimal(12, 2)
  taxable     Boolean           @default(false)
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  payroll     Payroll           @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([payrollId, type])
  @@map("payroll_details")
}

model GovernmentRule {
  id            String            @id @default(uuid()) @db.Uuid
  code          String            @unique
  name          String
  agency        GovernmentAgency
  description   String?
  status        RuleStatus        @default(DRAFT)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  tables        GovernmentTable[]

  @@index([agency, status])
  @@map("government_rules")
}

model GovernmentTable {
  id               String         @id @default(uuid()) @db.Uuid
  governmentRuleId String         @db.Uuid
  sequence         Int
  rangeStart       Decimal?       @db.Decimal(12, 2)
  rangeEnd         Decimal?       @db.Decimal(12, 2)
  baseAmount       Decimal?       @db.Decimal(12, 2)
  employeeRate     Decimal?       @db.Decimal(8, 4)
  employerRate     Decimal?       @db.Decimal(8, 4)
  multiplier       Decimal?       @db.Decimal(8, 4)
  formulaKey       String?
  metadata         Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  governmentRule   GovernmentRule @relation(fields: [governmentRuleId], references: [id], onDelete: Cascade)

  @@unique([governmentRuleId, sequence])
  @@index([governmentRuleId])
  @@map("government_tables")
}

model LeaveCredit {
  id            String    @id @default(uuid()) @db.Uuid
  employeeId    String    @db.Uuid
  leaveTypeCode String
  leaveTypeName String
  balance       Decimal   @default(0) @db.Decimal(8, 2)
  used          Decimal   @default(0) @db.Decimal(8, 2)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeCode])
  @@map("leave_credits")
}

model HolidayRule {
  id                           String      @id @default(uuid()) @db.Uuid
  code                         String      @unique
  name                         String
  type                         HolidayType
  description                  String?
  effectiveFrom                DateTime?
  effectiveTo                  DateTime?
  rateMultiplier               Decimal?    @db.Decimal(8, 4)
  overtimeMultiplier           Decimal?    @db.Decimal(8, 4)
  nightDifferentialMultiplier  Decimal?    @db.Decimal(8, 4)
  restDayMultiplier            Decimal?    @db.Decimal(8, 4)
  isActive                     Boolean     @default(true)
  metadata                     Json?
  createdAt                    DateTime    @default(now())
  updatedAt                    DateTime    @updatedAt

  @@index([type, isActive])
  @@map("holiday_rules")
}

model Attendance {
  id               String           @id @default(uuid()) @db.Uuid
  employeeId       String           @db.Uuid
  attendanceDate   DateTime
  status           AttendanceStatus @default(PRESENT)
  scheduledIn      DateTime?
  scheduledOut     DateTime?
  actualIn         DateTime?
  actualOut        DateTime?
  regularHours     Decimal          @default(0) @db.Decimal(8, 2)
  overtimeHours    Decimal          @default(0) @db.Decimal(8, 2)
  nightDiffHours   Decimal          @default(0) @db.Decimal(8, 2)
  tardinessMinutes Int              @default(0)
  undertimeMinutes Int              @default(0)
  notes            String?
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  employee         Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, attendanceDate])
  @@index([attendanceDate, status])
  @@map("attendances")
}

model Allowance {
  id           String             @id @default(uuid()) @db.Uuid
  employeeId   String             @db.Uuid
  code         String
  name         String
  description  String?
  amount       Decimal            @db.Decimal(12, 2)
  frequency    AllowanceFrequency
  taxable      Boolean            @default(false)
  isActive     Boolean            @default(true)
  effectiveFrom DateTime?
  effectiveTo  DateTime?
  metadata     Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  employee     Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, isActive])
  @@map("allowances")
}

model Deduction {
  id            String             @id @default(uuid()) @db.Uuid
  employeeId    String             @db.Uuid
  code          String
  name          String
  description   String?
  type          DeductionType      @default(OTHER)
  amount        Decimal            @db.Decimal(12, 2)
  frequency     DeductionFrequency
  isActive      Boolean            @default(true)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  metadata      Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  employee      Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, isActive])
  @@map("deductions")
}

model CompanySetting {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique
  name        String
  description String?
  value       String?
  valueType   SettingValueType @default(STRING)
  isEditable  Boolean          @default(true)
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("company_settings")
}

model AuditLog {
  id          String      @id @default(uuid()) @db.Uuid
  actorUserId String?     @db.Uuid
  actorEmail  String?
  entityType  String
  entityId    String
  action      AuditAction
  changes     Json?
  metadata    Json?
  createdAt   DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@map("audit_logs")
}
