generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model GovernmentRule {
  id            String            @id @default(uuid()) @db.Uuid
  code          String            @unique
  name          String
  agency        GovernmentAgency
  description   String?
  status        RuleStatus        @default(DRAFT)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  tables        GovernmentTable[]

  @@index([agency, status])
  @@map("government_rules")
}

model GovernmentTable {
  id               String         @id @default(uuid()) @db.Uuid
  governmentRuleId String         @db.Uuid
  sequence         Int
  rangeStart       Decimal?       @db.Decimal(12, 2)
  rangeEnd         Decimal?       @db.Decimal(12, 2)
  baseAmount       Decimal?       @db.Decimal(12, 2)
  employeeRate     Decimal?       @db.Decimal(8, 4)
  employerRate     Decimal?       @db.Decimal(8, 4)
  multiplier       Decimal?       @db.Decimal(8, 4)
  formulaKey       String?
  metadata         Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  governmentRule   GovernmentRule @relation(fields: [governmentRuleId], references: [id], onDelete: Cascade)

  @@unique([governmentRuleId, sequence])
  @@index([governmentRuleId])
  @@map("government_tables")
}

model HolidayRule {
  id                          String      @id @default(uuid()) @db.Uuid
  code                        String      @unique
  name                        String
  type                        HolidayType
  description                 String?
  effectiveFrom               DateTime?
  effectiveTo                 DateTime?
  rateMultiplier              Decimal?    @db.Decimal(8, 4)
  overtimeMultiplier          Decimal?    @db.Decimal(8, 4)
  nightDifferentialMultiplier Decimal?    @db.Decimal(8, 4)
  restDayMultiplier           Decimal?    @db.Decimal(8, 4)
  isActive                    Boolean     @default(true)
  metadata                    Json?
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt

  @@index([type, isActive])
  @@map("holiday_rules")
}

model UserSetting {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  key       String
  value     String?
  valueType SettingValueType @default(STRING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, key])
  @@index([userId])
  @@map("user_settings")
}

model PayrollRun {
  id                 String       @id @default(uuid()) @db.Uuid
  userId             String       @db.Uuid
  payrollPeriod      DateTime
  payFrequency       PayFrequency
  periodKey          String
  monthlySalaryBasis Decimal      @db.Decimal(12, 2)
  grossPay           Decimal      @db.Decimal(12, 2)
  totalDeductions    Decimal      @db.Decimal(12, 2)
  totalContributions Decimal      @db.Decimal(12, 2)
  totalTax           Decimal      @db.Decimal(12, 2)
  netPay             Decimal      @db.Decimal(12, 2)
  snapshot           Json
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([userId, payrollPeriod])
  @@unique([userId, payFrequency, periodKey])
  @@map("payroll_runs")
}

enum GovernmentAgency {
  BIR
  SSS
  PHILHEALTH
  PAG_IBIG
  DOLE
  COMPANY
}

enum RuleStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum HolidayType {
  REGULAR
  SPECIAL
  COMPANY
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

enum PayFrequency {
  MONTHLY
  SEMI_MONTHLY
  WEEKLY
}
