# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=PayEngine

# Supabase (from project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase PostgreSQL (Transaction pooler / direct URL)
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Optional direct URL for migrations in restrictive environments
DIRECT_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Comma-separated list of admin emails (bootstrap authorization)
AUTH_ADMIN_EMAILS=admin@company.com
